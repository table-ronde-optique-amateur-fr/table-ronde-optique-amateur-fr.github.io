---
import type { Speaker } from "../data/parseSpeakers";
import type { TalkResources } from "../data/types";

interface Props {
    speakers: Speaker[];
    resources: Record<string, TalkResources>;
    compact?: boolean;
}

const { speakers, resources, compact = false } = Astro.props;
---

<section class:list={["speakers", { compact }]}>
    <h2>Intervenants</h2>
    <div class="speakers-grid">
        {speakers.map((speaker) => {
            const needsTruncation = !compact && speaker.description.length > 240;
            const truncated = needsTruncation
                ? speaker.description.slice(0, 240).trimEnd() + "…"
                : speaker.description;
            const res = resources[speaker.name];
            return (
                <article class="speaker-card">
                    {speaker.photoPath.length ? (
                        <img
                            src={speaker.photoPath}
                            alt={`Photo de ${speaker.name}`}
                            class="speaker-photo"
                            loading="lazy"
                        />
                    ) : (
                        <div />
                    )}
                    <div class="speaker-info">
                        <h3>{speaker.name}</h3>
                        {speaker.website ? <h5 style="font-size: 0.65rem"><a href={speaker.website} target="_blank">{speaker.website}</a></h5> : <div/> }
                        <h4>{speaker.title}</h4>
                        {!compact && (
                            <p
                                class="description"
                                data-full={speaker.description}
                                data-truncated={truncated}
                            >
                                {truncated}
                            </p>
                        )}
                        {needsTruncation && (
                            <button class="expand-btn" type="button">
                                Lire la suite
                            </button>
                        )}
                        <span class="speaker-resources">
                            {res?.video && (
                                <a href={res.video} target="_blank" rel="noopener" class="resource-link resource-video">
                                    ▶ Vidéo
                                </a>
                            )}
                            {res?.slides && (
                                <a href={res.slides} target="_blank" class="resource-link resource-slides">
                                    Slides
                                </a>
                            )}
                        </span>
                    </div>
                </article>
            );
        })}
    </div>
</section>

<script>
    document.querySelectorAll(".expand-btn").forEach((btn) => {
        btn.addEventListener("click", () => {
            const description = btn.previousElementSibling as HTMLElement;
            const isExpanded = btn.getAttribute("data-expanded") === "true";

            if (isExpanded) {
                description.textContent = description.dataset.truncated!;
                btn.textContent = "Lire la suite";
                btn.setAttribute("data-expanded", "false");
            } else {
                description.textContent = description.dataset.full!;
                btn.textContent = "Réduire";
                btn.setAttribute("data-expanded", "true");
            }
        });
    });
</script>

<style>
    .speakers {
        margin: 2rem 0;
        width: 100vw;
        margin-left: calc(50% - 50vw);
        padding: 2rem 1rem;
        box-sizing: border-box;
    }

    .speakers h2 {
        max-width: 1200px;
        margin: 0 auto 1.5rem;
    }

    .speakers-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 2rem;
        max-width: 1200px;
        margin: 0 auto;
    }

    .speaker-card {
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        gap: 0.75rem;
        padding: 1rem;
        border: 1px solid #ddd;
        border-radius: 8px;
        background: #fafafa;
    }

    .speaker-photo {
        width: 120px;
        height: 120px;
        object-fit: cover;
        border-radius: 50%;
        flex-shrink: 0;
    }

    .speaker-info h3 {
        margin: 0 0 0.5rem 0;
    }

    .speaker-info h4 {
        margin: 0 0 0.5rem 0;
        color: #555;
        font-weight: normal;
        font-style: italic;
    }

    .speaker-info p {
        margin: 0;
        font-size: 0.875rem;
        line-height: 1.4;
    }

    .speaker-resources {
        display: flex;
        justify-content: center;
        gap: 0.3rem;
        margin-top: 0.5rem;
    }

    .resource-link {
        display: inline-block;
        padding: 0.25rem 0.6rem;
        font-size: 0.8rem;
        border-radius: 3px;
        text-decoration: none;
        border: 1px solid #ccc;
        color: #666;
    }

    .resource-link:hover {
        background: rgba(0, 0, 0, 0.07);
        color: #333;
    }

    .speakers.compact .speaker-photo {
        width: 72px;
        height: 72px;
    }

    .speakers.compact .speaker-card {
        padding: 0.85rem;
    }

    .speakers.compact .speaker-resources {
        margin-top: 0.75rem;
        gap: 0.5rem;
    }

    .speakers.compact .resource-link {
        padding: 0.45rem 0.9rem;
        font-size: 0.9rem;
        font-weight: 600;
        border-width: 1px;
    }

    .speakers.compact .resource-video {
        background: var(--accent, #2337ff);
        border-color: var(--accent, #2337ff);
        color: #fff;
    }

    .speakers.compact .resource-video:hover {
        filter: brightness(1.1);
        color: #fff;
    }

    .speakers.compact .resource-slides {
        border-color: var(--accent, #2337ff);
        color: var(--accent, #2337ff);
    }

    .speakers.compact .resource-slides:hover {
        background: var(--accent, #2337ff);
        color: #fff;
    }

    .expand-btn {
        margin-top: 0.5rem;
        padding: 0;
        background: none;
        border: none;
        color: var(--accent, #4a90d9);
        cursor: pointer;
        font-size: 0.9rem;
    }

    .expand-btn:hover {
        text-decoration: underline;
    }

    @media (max-width: 600px) {
        .speakers-grid {
            grid-template-columns: 1fr;
            gap: 1rem;
        }

        .speaker-card {
            padding: 1rem;
        }

        .speaker-photo {
            width: 100px;
            height: 100px;
        }
    }
</style>
