---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import ArchiveSpeakers from "../components/ArchiveSpeakers.astro";
import { loadSpeakers } from "../data/parseSpeakers";
import { resources as edition2026Resources } from "../data/2026/edition";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";

const edition2026Speakers = loadSpeakers(2026);
---

<!doctype html>
<html lang="fr">
    <head>
        <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} image="/table-ronde-optique-amateur-affiche.jpg" />
    </head>
    <body>
        <Header />
        <main>
            <section class="hero">
                <h1>Table ronde optique amateur francophone</h1>
                <p class="subtitle">
                    Un événement en ligne visant à partager et échanger autour des pratiques d'optique amateur, en français.
                </p>
                <p class="thanks">
                    Merci à tous les spectateurs et intervenants de l'édition 2026&nbsp;!
                </p>
            </section>

            <section class="last-edition">
                <h2>Édition 2026 — 4 et 5 mars</h2>
                <p class="last-edition-intro">
                    Les supports et vidéos des interventions sont désormais disponibles.
                    Retrouvez le <a href="/archive/2026">programme complet</a> ou accédez directement aux ressources de chaque intervenant&nbsp;ci-dessous.
                </p>
            </section>

            <ArchiveSpeakers speakers={edition2026Speakers} resources={edition2026Resources} compact />

            <section class="next-edition">
                <h2>Prochaine édition</h2>
                <p>
                    Une prochaine édition est en préparation. Les informations seront publiées ici dès qu'elles seront disponibles.
                </p>
            </section>
        </main>
        <Footer />
    </body>
</html>

<style>
    main {
        max-width: 800px;
        margin: 0 auto;
        padding: 2rem 1rem;
    }

    .hero {
        text-align: center;
        margin-bottom: 3rem;
    }

    .hero h1 {
        margin: 0 0 0.5rem 0;
    }

    .hero .thanks {
        font-size: 1.25rem;
        color: var(--accent, #2337ff);
        font-weight: 600;
    }

    .hero .subtitle {
        color: #555;
        max-width: 600px;
        margin: 0.5rem auto 0;
    }

    section {
        margin-bottom: 2rem;
    }

    section h2 {
        margin-bottom: 1rem;
    }

    .last-edition-intro {
        max-width: 700px;
    }
</style>
